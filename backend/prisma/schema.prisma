generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../../docs/ER図.svg"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  email        String        @unique @db.VarChar(254)
  name         String        @db.VarChar(255)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  roleId       Int           @map("role_id")
  deletedAt    DateTime?     @map("deleted_at")
  readingInfos ReadingInfo[]
  role         Role          @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id                  Int                  @id @default(autoincrement())
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  name                String               @unique @db.VarChar(255)
  roleBookPermissions RoleBookPermission[]
  users               User[]

  @@map("roles")
}

model Book {
  id                  Int                  @id @default(autoincrement())
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  title               String               @db.VarChar(255)
  authorName          String?              @map("author_name") @db.VarChar(255)
  publishedAt         DateTime?            @map("published_at") @db.Date
  publisher           String?              @db.VarChar(255)
  description         String?
  deletedAt           DateTime?            @map("deleted_at")
  categoryId          Int                  @map("category_id")
  pageTurnDirection   String               @default("ltr") @map("page_turn_direction") @db.VarChar(50)
  bookFiles           BookFile[]
  category            Category             @relation(fields: [categoryId], references: [id])
  readingInfos        ReadingInfo[]
  roleBookPermissions RoleBookPermission[]

  @@index([title, authorName])
  @@map("books")
}

model Category {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  name         String   @unique @db.VarChar(255)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  books        Book[]

  @@map("categories")
}

model BookFile {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  extension        String   @db.VarChar(10)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  filePath         String   @map("file_path") @db.VarChar(255)
  originalFileName String   @map("original_file_name") @db.VarChar(255)
  storedFileName   String   @map("stored_file_name") @db.VarChar(255)
  fileSize         Int      @map("file_size")
  bookId           Int      @map("book_id")
  book             Book     @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@map("book_files")
}

model ReadingInfo {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  currentPosition String?  @map("current_position") @db.VarChar(255)
  readStatus      String   @default("unread") @map("read_status") @db.VarChar(50)
  userId          Int      @map("user_id")
  bookId          Int      @map("book_id")
  book            Book     @relation(fields: [bookId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@map("reading_infos")
}

model RoleBookPermission {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  bookId    Int      @map("book_id")
  roleId    Int      @map("role_id")
  book      Book     @relation(fields: [bookId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([roleId, bookId])
  @@index([roleId])
  @@index([bookId])
  @@map("role_book_permissions")
}
